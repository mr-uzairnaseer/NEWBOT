[Unit]
Description=AI Outbound Voice Bot Service
After=network.target postgresql.service redis-server.service

[Service]
User=root
WorkingDirectory=/opt/voicebot
EnvironmentFile=/opt/voicebot/.env
ExecStart=/opt/voicebot/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080 --workers 4
Restart=always
RestartSec=5
StandardOutput=append:/var/log/voicebot.log
StandardError=append:/var/log/voicebot.error.log

[Install]
WantedBy=multi-user.target
